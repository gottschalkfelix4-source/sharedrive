# =============================================================
#  ShareDrive – Minimal environment configuration
#  The admin account and all app settings are configured
#  in the web UI after first start.
# =============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=sharedrive
POSTGRES_PASSWORD=change_me_db
POSTGRES_DB=sharedrive
DATABASE_URL=postgresql://sharedrive:change_me_db@postgres:5432/sharedrive

# ── MinIO Object Storage ─────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=sharedrive

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Security (IMPORTANT: change before going live!) ──────────
JWT_SECRET=change-me-to-a-long-random-secret-string
